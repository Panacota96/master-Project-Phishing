# Copy this file to terraform.tfvars and fill in the values
# Alternatively, use terraform/env/dev.tfvars.example or terraform/env/prod.tfvars.example

aws_region     = "eu-west-3"
environment    = "prod"
app_name       = "en-garde"
secret_key     = "CHANGE-ME-to-a-long-random-string"

# Optional overrides
# lambda_memory_size = 512
# lambda_timeout     = 30
# domain_name        = "engarde.esme.fr"
# route53_zone_id    = "Z0123456789ABCDEFGHIJ"
# redis_node_type    = "cache.t4g.small"
# campaign_schedule_enabled = false
# campaign_schedule_expression = "rate(1 day)"
